{
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.py"
        },
        {
            "src": "/js/env.js",
            "dest": "api/index.py"
        },
        {
            "src": "/(.+)",
            "dest": "/frontend/$1"
        }
    ],
    "env": {
        "PYTHONPATH": "."
    }
}